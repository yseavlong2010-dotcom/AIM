    local H = C:FindFirstChildOfClass("Humanoid"); if H and H.Health <= 0 then return false end
    if Config.TeamCheck then
        if P.Team and LocalPlayer.Team and P.Team == LocalPlayer.Team then return false end
        pcall(function() if P.TeamColor and LocalPlayer.TeamColor and P.TeamColor == LocalPlayer.TeamColor then return false end end)
    end
    if C:FindFirstChild("ForceField") then return false end
    return true
end

local function DrawOOFArrow(TPos, Obj, Col)
