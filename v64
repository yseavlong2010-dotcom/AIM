-- RENDERSTEPPED 2: LATE CAMERA HOOK & PRECISION SHOOT (V64 IMPERIAL)
RunService:BindToRenderStep("NoxeraAimV64", Enum.RenderPriority.Camera.Value + 200, function(dT)
    if Config.AimEnabled and LockedTarget and IsLocalAlive() then
        Camera = Workspace.CurrentCamera; if not Camera then return end
        local Center = Vector2.new(math.floor(Camera.ViewportSize.X / 2), math.floor(Camera.ViewportSize.Y / 2))
        local PPos = GetOmniPrediction(LockedTarget)
        
        local APos, InScreen = Camera:WorldToViewportPoint(PPos)
        if InScreen and Config.AutoShoot and not Config.TriggerBot and (not Config.WallCheck or IsVisibleDeep(LockedTarget)) then
            local aimDist = (Vector2.new(APos.X, APos.Y) - Center).Magnitude
            if aimDist < 35 then UniversalShoot(APos) end 
        end

        if Config.AimMethod == "Mouse" and HasMouseMoverel then
            if InScreen then
                local dX = APos.X - Center.X; local dY = APos.Y - Center.Y
                if Config.AimMode == "Rage" then mousemoverel(dX, dY)
                elseif Config.AimMode == "Bezier" then local ro = Vector2.new(math.random(-40,40), math.random(-40,40)); local bCurve = BezierInterpolate(dT * Config.Smoothness, Vector2.new(0,0), ro, Vector2.new(dX, dY)); mousemoverel(math.floor(bCurve.X), math.floor(bCurve.Y))
                else local sm = math.clamp(Config.Smoothness / 10, 0.05, 1); mousemoverel(math.floor(dX * sm), math.floor(dY * sm)) end
            end
        else
            local TCFrame = CFrame.lookAt(Camera.CFrame.Position, PPos)
            if Config.AimMode == "Rage" then 
                Camera.CFrame = TCFrame 
            else 
                Camera.CFrame = Camera.CFrame:Lerp(TCFrame, math.clamp(dT * (Config.Smoothness * 3), 0.1, 1)) 
            end
        end
    end
end)

