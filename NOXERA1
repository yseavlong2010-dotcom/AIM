local CombatController = {
    LockedTarget = nil,
    FOVDrawing = Drawing.new("Circle"),
    LastShootTick = 0,
    VelocityHistory = {} -- Resolver cache
}
CombatController.FOVDrawing.Thickness = 1.2
CombatController.FOVDrawing.Filled = false

-- Resolver Logic (Chống Anti-Aim xoay)
function CombatController:ResolveVelocity(player, currentVel)
    if not ConfigManager.Data.Resolver then return currentVel end
    if not self.VelocityHistory[player] then self.VelocityHistory[player] = {} end
    
    table.insert(self.VelocityHistory[player], 1, currentVel)
    if #self.VelocityHistory[player] > 5 then table.remove(self.VelocityHistory[player], 6) end
    
    local avgX, avgY, avgZ = 0, 0, 0
    for _, v in ipairs(self.VelocityHistory[player]) do
        avgX = avgX + v.X; avgY = avgY + v.Y; avgZ = avgZ + v.Z
    end
    local count = #self.VelocityHistory[player]
    return Vector3.new(avgX/count, avgY/count, avgZ/count)
end

function CombatController:GetTarget()
    local bestTarget = nil
    local bestScore = math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local char = p.Character
        if not char or Utils.IsKnocked(char) then continue end
        
        local aimPart = char:FindFirstChild(ConfigManager.Data.AimPart)
        local hum = char:FindFirstChild("Humanoid")
        if not aimPart or not hum or hum.Health <= 0 then continue end

        local pos, onScreen = Camera:WorldToViewportPoint(aimPart.Position)
        if not onScreen then continue end

        local distToCenter = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude
        if distToCenter > ConfigManager.Data.AimFOV then continue end

        if ConfigManager.Data.WallCheck and not Utils.IsVisible(aimPart) then continue end

        -- Target Priority Logic
        local score = distToCenter
        if ConfigManager.Data.TargetPriority == "Health" then
            score = hum.Health
        end

        if score < bestScore then
            bestScore = score
            bestTarget = {Part = aimPart, Player = p, Char = char, Hum = hum}
        end
    end
    return bestTarget
end

function CombatController:HandleAimbot()
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    self.FOVDrawing.Position = screenCenter
    self.FOVDrawing.Radius = ConfigManager.Data.AimFOV
    
    if NOXERA_ENGINE.UI.AimToggleState then
        self.FOVDrawing.Visible = true
        self.LockedTarget = self:GetTarget()
        
        if self.LockedTarget then
            self.FOVDrawing.Color = Color3.fromRGB(0, 255, 0) -- Xanh khi lock
            local targetPart = self.LockedTarget.Part
            local resolvedVel = self:ResolveVelocity(self.LockedTarget.Player, targetPart.Velocity)
            
            -- Tính toán Prediction
            local predPos = targetPart.Position + (resolvedVel * ConfigManager.Data.Prediction)
            
            if ConfigManager.Data.AimMode == "Rage" then
                Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, predPos)
            else
                -- Legit Mode: Thêm bezier/smooth
                local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, predPos)
                Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, ConfigManager.Data.Smoothness)
            end
        else
            self.FOVDrawing.Color = Color3.fromRGB(255, 255, 255)
        end
    else
        self.FOVDrawing.Visible = false
        self.LockedTarget = nil
    end
end

function CombatController:HandleTriggerBot()
    if not ConfigManager.Data.AutoShoot then return end
    if tick() - self.LastShootTick < ConfigManager.Data.TriggerDelay then return end

    local rayOrigin = Camera.CFrame.Position
    local rayDirection = Camera.CFrame.LookVector * 1000 
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {LocalPlayer.Character, Camera, Workspace:FindFirstChild("Ignored")}
    
    local result = Workspace:Raycast(rayOrigin, rayDirection, rayParams)
    if result and result.Instance then
        local model = result.Instance:FindFirstAncestorOfClass("Model")
        if model and model:FindFirstChild("Humanoid") and not Utils.IsKnocked(model) then
            -- HitChance Logic
            if math.random(1, 100) <= ConfigManager.Data.HitChance then
                pcall(function()
                    local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                    if tool then tool:Activate() end
                end)
                self.LastShootTick = tick()
            end
        end
    end
end

