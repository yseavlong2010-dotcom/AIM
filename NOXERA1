local MiscController = {}

function MiscController:HandleMovement()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")

    if hum and hrp then
        if ConfigManager.Data.SpeedHack then hum.WalkSpeed = ConfigManager.Data.WalkSpeed else hum.WalkSpeed = 16 end
        if ConfigManager.Data.JumpHack then hum.JumpPower = ConfigManager.Data.JumpPower; hum.UseJumpPower = true end
        
        -- Macro Wallet Logic
        if ConfigManager.Data.MacroEnabled then
            local tool = char:FindFirstChildOfClass("Tool")
            if tool and tool.Name:lower():match("wallet") and hum.MoveDirection.Magnitude > 0 then
                hrp.Velocity = Vector3.new(
                    hum.MoveDirection.X * (ConfigManager.Data.MacroSpeed * 20),
                    hrp.Velocity.Y,
                    hum.MoveDirection.Z * (ConfigManager.Data.MacroSpeed * 20)
                )
            end
        end

        -- Spinbot (Anti-Aim)
        if ConfigManager.Data.SpinBot then
            hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(ConfigManager.Data.SpinSpeed), 0)
        end
        
        -- Anti Bag
        if ConfigManager.Data.AntiBag then
            if char:FindFirstChild("Christmas_Sock") or char:FindFirstChild("Bag") then
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
                hrp.CFrame = hrp.CFrame * CFrame.Angles(math.random(-1,1), math.rad(50), 0)
            end
        end
    end
end

function MiscController:HandleMisc()
    local char = LocalPlayer.Character
    if not char then return end

    -- Hitbox Expander
    if ConfigManager.Data.HitboxExpander then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local thrp = p.Character:FindFirstChild("HumanoidRootPart")
                if thrp and not Utils.IsKnocked(p.Character) then
                    thrp.Size = Vector3.new(ConfigManager.Data.HitboxSize, ConfigManager.Data.HitboxSize, ConfigManager.Data.HitboxSize)
                    thrp.Transparency = 0.6; thrp.CanCollide = false; thrp.Color = Color3.new(1,0,0)
                end
            end
        end
    end

    -- Auto Stomp (Da Hood Specific)
    if ConfigManager.Data.AutoStomp then
        if CombatController.LockedTarget and Utils.IsKnocked(CombatController.LockedTarget.Char) then
            pcall(function()
                ReplicatedStorage.MainEvent:FireServer("Stomp")
            end)
        end
    end

    -- Fullbright
    if ConfigManager.Data.Fullbright then
        Lighting.Ambient = Color3.new(1, 1, 1); Lighting.GlobalShadows = false
    else
        Lighting.Ambient = Color3.fromRGB(127, 127, 127); Lighting.GlobalShadows = true
    end
end

UserInputService.JumpRequest:Connect(function()
    if ConfigManager.Data.InfJump and LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
    end
end)

