local ESPController = {
    Pool = { Boxes = {}, Texts = {}, Lines = {} },
    Active = {}
}

function ESPController:GetDrawing(typeStr)
    local poolType = typeStr == "Square" and "Boxes" or (typeStr == "Text" and "Texts" or "Lines")
    if #self.Pool[poolType] > 0 then
        local obj = table.remove(self.Pool[poolType])
        obj.Visible = false
        return obj
    end
    local obj = Drawing.new(typeStr)
    obj.Visible = false
    return obj
end

function ESPController:Recycle(obj, typeStr)
    if not obj then return end
    obj.Visible = false
    local poolType = typeStr == "Square" and "Boxes" or (typeStr == "Text" and "Texts" or "Lines")
    table.insert(self.Pool[poolType], obj)
end

function ESPController:InitPlayer(player)
    if self.Active[player] then return end
    self.Active[player] = {
        Box = self:GetDrawing("Square"),
        Name = self:GetDrawing("Text"),
        HPBG = self:GetDrawing("Square"),
        HP = self:GetDrawing("Square"),
        Tracer = self:GetDrawing("Line")
    }
    -- Setup mặc định
    self.Active[player].Box.Thickness = 1.5; self.Active[player].Box.Filled = false; self.Active[player].Box.Color = Color3.new(1,1,1)
    self.Active[player].Name.Size = 13; self.Active[player].Name.Center = true; self.Active[player].Name.Outline = true; self.Active[player].Name.Color = Color3.new(1,1,1)
    self.Active[player].HPBG.Filled = true; self.Active[player].HPBG.Color = Color3.new(0,0,0)
    self.Active[player].HP.Filled = true; self.Active[player].HP.Color = Color3.new(0,1,0)
    self.Active[player].Tracer.Thickness = 1.5; self.Active[player].Tracer.Color = Color3.fromRGB(80, 150, 255)
end

function ESPController:ClearPlayer(player)
    if self.Active[player] then
        self:Recycle(self.Active[player].Box, "Square")
        self:Recycle(self.Active[player].Name, "Text")
        self:Recycle(self.Active[player].HPBG, "Square")
        self:Recycle(self.Active[player].HP, "Square")
        self:Recycle(self.Active[player].Tracer, "Line")
        self.Active[player] = nil
    end
end

function ESPController:Render()
    if not ConfigManager.Data.ESPEnabled then
        for p, _ in pairs(self.Active) do self:ClearPlayer(p) end
        return
    end

    local ScreenBottom = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local head = char and char:FindFirstChild("Head")

        if not char or not hum or hum.Health <= 0 or Utils.IsKnocked(char) or not hrp or not head then
            self:ClearPlayer(player); continue
        end

        local dist = (Camera.CFrame.Position - hrp.Position).Magnitude
        if dist > ConfigManager.Data.MaxRender then self:ClearPlayer(player); continue end

        -- Culling: Check if behind camera
        local dir = (hrp.Position - Camera.CFrame.Position).Unit
        if Camera.CFrame.LookVector:Dot(dir) < 0 then self:ClearPlayer(player); continue end

        local topPos, topVis = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
        local botPos, botVis = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))

        if topVis and botVis then
            self:InitPlayer(player)
            local esp = self.Active[player]
            local boxH = math.abs(topPos.Y - botPos.Y)
            local boxW = boxH * 0.55
            local boxPos = Vector2.new(topPos.X - boxW / 2, topPos.Y)

            if ConfigManager.Data.ESPBox then
                esp.Box.Size = Vector2.new(boxW, boxH); esp.Box.Position = boxPos; esp.Box.Visible = true
            else esp.Box.Visible = false end

            if ConfigManager.Data.ESPName then
                esp.Name.Text = player.Name; esp.Name.Position = Vector2.new(topPos.X, topPos.Y - 15); esp.Name.Visible = true
            else esp.Name.Visible = false end

            if ConfigManager.Data.ESPHP then
                local ratio = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                esp.HPBG.Size = Vector2.new(4, boxH); esp.HPBG.Position = Vector2.new(boxPos.X - 6, boxPos.Y); esp.HPBG.Visible = true
                esp.HP.Size = Vector2.new(2, boxH * ratio); esp.HP.Position = Vector2.new(boxPos.X - 5, topPos.Y + boxH - (boxH * ratio))
                esp.HP.Color = Color3.fromRGB(255 - (255 * ratio), 255 * ratio, 0); esp.HP.Visible = true
            else esp.HPBG.Visible = false; esp.HP.Visible = false end

            if ConfigManager.Data.ESPTracer then
                esp.Tracer.From = ScreenBottom; esp.Tracer.To = Vector2.new(botPos.X, botPos.Y); esp.Tracer.Visible = true
            else esp.Tracer.Visible = false end
        else
            self:ClearPlayer(player)
        end
    end
end

