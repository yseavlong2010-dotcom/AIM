            TweenService:Create(swK, TweenInfo.new(0.2), {Position = ConfigManager.Data[configKey] and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)}):Play()
        end)
    end

    local function MakeSlider(name, configKey, min, max)
        local f = Instance.new("Frame", Content)
        f.Size, f.BackgroundColor3 = UDim2.new(1, 0, 0, 55), Color3.fromRGB(20, 20, 28)
        Instance.new("UICorner", f).CornerRadius = UDim.new(0, 6)
        
        local l = Instance.new("TextLabel", f)
        l.Size, l.Position, l.BackgroundTransparency, l.Text, l.TextColor3, l.Font, l.TextSize, l.TextXAlignment = UDim2.new(1, -20, 0, 25), UDim2.new(0, 10, 0, 5), 1, name .. ": " .. ConfigManager.Data[configKey], Color3.new(1,1,1), Enum.Font.GothamSemibold, 12, Enum.TextXAlignment.Left
        
        local sBG = Instance.new("TextButton", f)
        sBG.Size, sBG.Position, sBG.BackgroundColor3, sBG.Text = UDim2.new(1, -20, 0, 8), UDim2.new(0, 10, 0, 35), Color3.fromRGB(40, 40, 50), ""
        Instance.new("UICorner", sBG).CornerRadius = UDim.new(1, 0)
        
        local fill = Instance.new("Frame", sBG)
        fill.Size, fill.BackgroundColor3 = UDim2.new((ConfigManager.Data[configKey] - min) / (max - min), 0, 1, 0), Color3.fromRGB(80, 150, 255)
        Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

        local d = false
        local function update(i)
            local x = math.clamp((i.Position.X - sBG.AbsolutePosition.X) / sBG.AbsoluteSize.X, 0, 1)
            local val = math.floor(min + (max - min) * x)
            ConfigManager.Data[configKey] = val
            fill.Size = UDim2.new(x, 0, 1, 0)
            l.Text = name .. ": " .. val
        end
        sBG.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then d = true; update(i) end end)
        UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then d = false end end)
        UserInputService.InputChanged:Connect(function(i) if d and (i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseMovement) then update(i) end end)
    end

    -- Khởi tạo UI Elements
    MakeToggle("TriggerBot (AutoShoot Raycast)", "AutoShoot")
    MakeToggle("Resolver (Anti-Desync)", "Resolver")
    MakeToggle("Wall Check", "WallCheck")
    MakeSlider("Aim FOV", "AimFOV", 10, 500)
    MakeSlider("Aim Smoothness", "Smoothness", 0.05, 1)
    MakeSlider("Trigger HitChance", "HitChance", 1, 100)
    
    MakeToggle("Enable ESP", "ESPEnabled")
    MakeToggle("ESP Boxes", "ESPBox")
    MakeToggle("ESP Names", "ESPName")
    MakeToggle("ESP Health", "ESPHP")
    
    MakeToggle("Wallet Macro (Da Hood)", "MacroEnabled")
    MakeSlider("Macro Speed", "MacroSpeed", 1, 10)
    MakeToggle("Spinbot", "SpinBot")
    MakeToggle("Anti-Bag / Sock", "AntiBag")
    MakeToggle("Auto Stomp K.O", "AutoStomp")
    MakeToggle("Hitbox Expander", "HitboxExpander")

    -- Mở/Đóng Main Window
    local OpenBtn = Instance.new("TextButton", gui)
    OpenBtn.Size, OpenBtn.Position, OpenBtn.BackgroundColor3, OpenBtn.Text, OpenBtn.TextColor3 = UDim2.new(0, 100, 0, 30), UDim2.new(0.5, -50, 0, -35), Color3.fromRGB(15, 15, 20), "Show Menu", Color3.new(1,1,1)
    Instance.new("UICorner", OpenBtn).CornerRadius = UDim.new(0, 6)
    
    CloseBtn.MouseButton1Click:Connect(function()
        MainFrame.Visible = false; OpenBtn.Position = UDim2.new(0.5, -50, 0, 10)
    end)
    OpenBtn.MouseButton1Click:Connect(function()
        MainFrame.Visible = true; OpenBtn.Position = UDim2.new(0.5, -50, 0, -35)
    end)
    
    self:Notify("Noxera V24 Loaded Successfully!", 3)
end

