local function TriggerHitFeedback()
    if Config.HitSound then HitAudio:Play() end
    if Config.HitMarker then HM_Alpha = 1 end
end

local function ExecuteShoot()
    if not IsLocalAlive() or UserInputService:GetFocusedTextBox() then return end
    if tick() - LastShootTick > Config.ShootDelay then
        LastShootTick = tick()
        TriggerHitFeedback()
        task.spawn(function()
            if Config.ShootMethod == "Tool" then
                local Tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
                if Tool then Tool:Activate() end
            elseif Config.ShootMethod == "Mouse API" then
                if mouse1click then mouse1click()
                elseif mouse1press then mouse1press() task.wait(0.01) mouse1release() end
            elseif Config.ShootMethod == "VIM" then
                local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
                pcall(function() VIM:SendMouseButtonEvent(center.X, center.Y, 0, true, game, 1); task.wait(0.01); VIM:SendMouseButtonEvent(center.X, center.Y, 0, false, game, 1) end)
            end
        end)
    end
end

local function IsValidTarget(Player)
    if Player == LocalPlayer then return false end
    local Char = Player.Character
    if not Char or not Char:IsDescendantOf(Workspace) then return false end 
    local Hum = Char:FindFirstChildOfClass("Humanoid")
    if not Hum or Hum.Health <= 0 then return false end
    if Config.TeamCheck and LocalPlayer.Team and Player.Team and LocalPlayer.Team == Player.Team then return false end
    if Char:FindFirstChild("ForceField") then return false end
    return true
end

local function GetAimPart(Char)
    local Hum = Char:FindFirstChildOfClass("Humanoid")
    if not Hum then return Char:FindFirstChild("HumanoidRootPart") end
    local part = Char:FindFirstChild(Config.AimPart)
    if not part then part = Char:FindFirstChild("HumanoidRootPart") or Char:FindFirstChild("Torso") end
    return part
end

local function IsVisibleDeep(TargetPart)
    local Origin = Camera.CFrame.Position
    local Direction = TargetPart.Position - Origin
    RayParams.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    local Result = Workspace:Raycast(Origin, Direction, RayParams)
    if not Result then return true end
    if Result.Instance:IsDescendantOf(TargetPart.Parent) then return true end
    return false
end

local function DrawOOFArrow(TargetPos, DrawingObj, Color)
    local CameraCFrame = Camera.CFrame
    local ObjectSpace = CameraCFrame:PointToObjectSpace(TargetPos)
    local Angle = math.atan2(ObjectSpace.X, ObjectSpace.Z)
    
    local Center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local Radius = 150 
    local X = Center.X + math.sin(Angle) * Radius
    local Y = Center.Y + math.cos(Angle) * Radius
    
    local P1 = Vector2.new(X, Y)
    local P2 = Vector2.new(Center.X + math.sin(Angle + 0.15) * (Radius - 20), Center.Y + math.cos(Angle + 0.15) * (Radius - 20))
    local P3 = Vector2.new(Center.X + math.sin(Angle - 0.15) * (Radius - 20), Center.Y + math.cos(Angle - 0.15) * (Radius - 20))
    
    DrawingObj.PointA = P1; DrawingObj.PointB = P2; DrawingObj.PointC = P3
    DrawingObj.Color = Color; DrawingObj.Visible = true
end

-- Tối ưu hóa: Acceleration Prediction
local function ResolveVelocity(TargetPart)
    local Vel = TargetPart.Velocity
    if Config.Resolver and (Vel.Magnitude > 120 or Vel.Y < -50) then Vel = Vector3.new(0,0,0) end
    return Vel
end

local function GetBallisticPrediction(TargetPart)
    local Dist = (TargetPart.Position - Camera.CFrame.Position).Magnitude
    local TimeToTarget = Dist / Config.BulletSpeed
    local ResolvedVel = ResolveVelocity(TargetPart)
    
    local PredVel = ResolvedVel * TimeToTarget * Config.Prediction
    local Drop = Vector3.new(0, (Workspace.Gravity * Config.GravityDrop * (TimeToTarget^2)) / 2, 0)
    return TargetPart.Position + PredVel + Drop
end

local function BezierInterpolate(t, p0, p1, p2)
    local u = 1 - t; return (u^2)*p0 + 2*u*t*p1 + (t^2)*p2
end

