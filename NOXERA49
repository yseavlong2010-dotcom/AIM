local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local Method = getnamecallmethod()
    local Args = {...}

    if Config.SilentAim and SilentTarget and IsLocalAlive() then
        if Method == "FindPartOnRayWithIgnoreList" or Method == "FindPartOnRayWithWhitelist" or Method == "FindPartOnRay" then
            local Origin = Args[1].Origin
            local Direction = (GetBallisticPrediction(SilentTarget) - Origin).unit * 5000
            Args[1] = Ray.new(Origin, Direction)
            return OldNamecall(self, unpack(Args))
        elseif Method == "Raycast" then
            local Origin = Args[1]
            local Direction = (GetBallisticPrediction(SilentTarget) - Origin).unit * 5000
            Args[2] = Direction
            return OldNamecall(self, unpack(Args))
        elseif Method == "FireServer" and typeof(Args[1]) == "Vector3" then
            Args[1] = GetBallisticPrediction(SilentTarget)
            return OldNamecall(self, unpack(Args))
        end
    end
    
    return OldNamecall(self, ...)
end)

