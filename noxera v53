local function CreateTab(Name, Icon, IsDefault)
    TabOrderCounter = TabOrderCounter + 1
    local Btn = Instance.new("TextButton", Sidebar)
    Btn.LayoutOrder = TabOrderCounter
    Btn.Size, Btn.BackgroundColor3, Btn.BackgroundTransparency = UDim2.new(1, 0, 0, 38), TAB_BG, IsDefault and 0 or 1
    Btn.Text, Btn.TextColor3, Btn.Font, Btn.TextSize, Btn.TextXAlignment = "   " .. Icon .. " " .. Name, IsDefault and CURRENT_ACCENT or DIM_TEXT, Enum.Font.GothamBold, 12, Enum.TextXAlignment.Left
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
    if IsDefault then table.insert(AccentObjects, Btn) end

    local Content = Instance.new("ScrollingFrame", ContentArea)
    Content.Name = Name
    Content.Size, Content.Position, Content.BackgroundTransparency, Content.ScrollBarThickness, Content.Visible = UDim2.new(1, -20, 1, -20), UDim2.new(0, 10, 0, 10), 1, 2, IsDefault
    Content.AutomaticCanvasSize = Enum.AutomaticSize.None 
    Content.CanvasSize = UDim2.new(0, 0, 0, 0)
    
    local Layout = Instance.new("UIListLayout", Content)
    Layout.Padding = UDim.new(0, 8)
    Layout.SortOrder = Enum.SortOrder.LayoutOrder

    table.insert(TabButtons, Btn); Tabs[Name] = Content

    Btn.MouseButton1Click:Connect(function()
        for _, b in pairs(TabButtons) do 
            TweenService:Create(b, TweenInfo.new(0.2), {BackgroundTransparency = 1, TextColor3 = DIM_TEXT}):Play()
            for i = #AccentObjects, 1, -1 do if AccentObjects[i] == b then table.remove(AccentObjects, i) end end
        end
        for _, c in pairs(Tabs) do c.Visible = false end
        TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundTransparency = 0, TextColor3 = CURRENT_ACCENT}):Play()
        table.insert(AccentObjects, Btn)
        Content.Visible = true
        SafeUpdateCanvas(Content, Layout)
    end)
    return {Frame = Content, Layout = Layout}
end

