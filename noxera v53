local function SafeUpdateCanvas(ContentFrame, Layout)
    task.spawn(function()
        task.wait(0.05)
        if ContentFrame and Layout then
            ContentFrame.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 20)
        end
