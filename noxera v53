                            local P1, Vis1 = Camera:WorldToViewportPoint(SafeVector(Part1.Position))
                            local P2, Vis2 = Camera:WorldToViewportPoint(SafeVector(Part2.Position))
                            if Vis1 or Vis2 then
                                e.Lines[i].From = Vector2.new(math.floor(P1.X), math.floor(P1.Y)); e.Lines[i].To = Vector2.new(math.floor(P2.X), math.floor(P2.Y))
                                e.Lines[i].Color = espColor; e.Lines[i].Visible = true
                            else e.Lines[i].Visible = false end
                        else e.Lines[i].Visible = false end
                    end
                else for _, line in pairs(e.Lines) do line.Visible = false end end

                if Config.BulletTracers then
                    e.Tracer.From = Vector2.new(Center.X, Camera.ViewportSize.Y - 20) 
                    e.Tracer.To = Vector2.new(math.floor(Pos.X), math.floor(Pos.Y))
                    e.Tracer.Color = espColor
                    e.Tracer.Visible = true
                else e.Tracer.Visible = false end
            end)
        else
            pcall(function()
                e.Box.Visible = false; e.Name.Visible = false; e.HP.Visible = false; e.Tracer.Visible = false
                for _, line in pairs(e.Lines) do line.Visible = false end
            end)
        end

        local AimP = GetAimPart(Char)
        if AimP and OnScreen then
            local APos = Camera:WorldToViewportPoint(SafeVector(AimP.Position))
            local Dist2D = (Vector2.new(APos.X, APos.Y) - Center).Magnitude
            
            if Config.TriggerBot and Dist2D <= 15 then
                if not Config.WallCheck or IsVisibleDeep(AimP) then TriggerTarget = AimP end
            end

            if (Config.AimEnabled or Config.SilentAim) and Dist2D < BestScore then
                if not Config.WallCheck or IsVisibleDeep(AimP) then
                    BestScore = Dist2D
                    if Config.SilentAim then SilentTarget = AimP else LockedTarget = AimP end
                    LastTargetHealth = Hum.Health
                end
            end
        end
    end

    if Config.TriggerBot and TriggerTarget then ExecuteShoot() end

    if Config.AimEnabled and LockedTarget and IsLocalAlive() then
        local PredPos = GetOmniPrediction(LockedTarget)
        
        if Config.AimMethod == "Mouse" and HasMouseMoverel then
            local TargetPos2D, onScreen2D = Camera:WorldToViewportPoint(PredPos)
            if onScreen2D then
                local DeltaX = (TargetPos2D.X - Center.X); local DeltaY = (TargetPos2D.Y - Center.Y)
                
                if Config.AimMode == "Rage" then mousemoverel(DeltaX, DeltaY)
                elseif Config.AimMode == "Bezier" then
                    local randOffset = Vector2.new(math.random(-40, 40), math.random(-40, 40))
                    local bCurve = BezierInterpolate(deltaTime * Config.Smoothness, Vector2.new(0,0), randOffset, Vector2.new(DeltaX, DeltaY))
                    mousemoverel(math.floor(bCurve.X), math.floor(bCurve.Y))
                else 
                    local sm = math.clamp(Config.Smoothness / 10, 0.05, 1)
                    mousemoverel(math.floor(DeltaX * sm), math.floor(DeltaY * sm))
                end
            end
        else
            local TargetCFrame = CFrame.lookAt(Camera.CFrame.Position, PredPos)
            if Config.AimMode == "Rage" then Camera.CFrame = TargetCFrame
            else 
                local lerpAlpha = math.clamp(deltaTime * (Config.Smoothness * 1.5), 0, 1)
                Camera.CFrame = Camera.CFrame:Lerp(TargetCFrame, lerpAlpha) 
            end
        end

        if Config.ShowTargetDot then
            local dp, ds = Camera:WorldToViewportPoint(PredPos)
            pcall(function()
                if ds then _G.TargetDot.Position = Vector2.new(math.floor(dp.X), math.floor(dp.Y)); _G.TargetDot.Visible = true else _G.TargetDot.Visible = false end
            end)
        else pcall(function() _G.TargetDot.Visible = false end) end
        
        if Config.AutoShoot and not Config.TriggerBot then
            if not Config.WallCheck or IsVisibleDeep(LockedTarget) then ExecuteShoot() end
        end
    else 
        pcall(function() _G.TargetDot.Visible = false end) 
    end
end)
table.insert(Connections, rStep)

local leaveCon = Players.PlayerRemoving:Connect(function(P)
    if _G.ESP_Cache and _G.ESP_Cache[P] then 
        for _, v in pairs(_G.ESP_Cache[P].Lines or {}) do pcall(function() v:Remove() end) end
        if _G.ESP_Cache[P].OOF then pcall(function() _G.ESP_Cache[P].OOF:Remove() end) end
        if _G.ESP_Cache[P].Tracer then pcall(function() _G.ESP_Cache[P].Tracer:Remove() end) end
        for k, v in pairs(_G.ESP_Cache[P]) do if type(v) ~= "table" then pcall(function() v:Remove() end) end end 
        _G.ESP_Cache[P] = nil 
    end
end)
