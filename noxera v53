local function SafeVector(v)
    if not v then return Vector3.zero end
    if v.X ~= v.X or v.Y ~= v.Y or v.Z ~= v.Z then return Vector3.zero end
    if math.abs(v.X) == math.huge or math.abs(v.Y) == math.huge or math.abs(v.Z) == math.huge then return Vector3.zero end
    return v
end

local function IsValidTarget(Player)
    if Player == LocalPlayer then return false end
    local Char = Player.Character
    if not Char or not Char:IsDescendantOf(Workspace) then return false end 
    local Hum = Char:FindFirstChildOfClass("Humanoid")
    if not Hum or Hum.Health <= 0 then return false end
    if Config.TeamCheck and LocalPlayer.Team and Player.Team and LocalPlayer.Team == Player.Team then return false end
    if Char:FindFirstChild("ForceField") then return false end
    return true
end

local function GetAimPart(Char)
    local Hum = Char:FindFirstChildOfClass("Humanoid")
    if not Hum then return Char:FindFirstChild("HumanoidRootPart") end
    local part = Char:FindFirstChild(Config.AimPart)
    if not part then part = Char:FindFirstChild("HumanoidRootPart") or Char:FindFirstChild("Torso") end
    return part
end

local function IsVisibleDeep(TargetPart)
    local Origin = SafeVector(Camera.CFrame.Position)
    local Direction = SafeVector(TargetPart.Position - Origin)
    RayParams.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    local Result = Workspace:Raycast(Origin, Direction, RayParams)
    if not Result then return true end
    if Result.Instance:IsDescendantOf(TargetPart.Parent) then return true end
    if Result.Instance.Transparency > 0.5 or not Result.Instance.CanCollide then return true end
    return false
end

local function DrawOOFArrow(TargetPos, DrawingObj, Color)
    if not DrawingObj or not DrawingObj.Visible ~= nil then return end
    local ObjectSpace = Camera.CFrame:PointToObjectSpace(SafeVector(TargetPos))
    local Angle = math.atan2(ObjectSpace.X, ObjectSpace.Z)
    
    if Angle ~= Angle then return end 
    
    local CenterX, CenterY = math.floor(Camera.ViewportSize.X/2), math.floor(Camera.ViewportSize.Y/2)
    local Radius = 150 
    local X = CenterX + math.sin(Angle) * Radius
    local Y = CenterY + math.cos(Angle) * Radius
    
    pcall(function()
        DrawingObj.PointA = Vector2.new(math.floor(X), math.floor(Y))
        DrawingObj.PointB = Vector2.new(math.floor(CenterX + math.sin(Angle + 0.15) * (Radius - 20)), math.floor(CenterY + math.cos(Angle + 0.15) * (Radius - 20)))
        DrawingObj.PointC = Vector2.new(math.floor(CenterX + math.sin(Angle - 0.15) * (Radius - 20)), math.floor(CenterY + math.cos(Angle - 0.15) * (Radius - 20)))
        DrawingObj.Color = Color; DrawingObj.Visible = true
    end)
end

local TargetHistory = {}
local function ResolverV4(TargetPart)
    local Vel = TargetPart.Velocity
    local Pos = SafeVector(TargetPart.Position)
    local Tick = tick()
    
    if Vel.X ~= Vel.X or Vel.Magnitude > 300 or math.abs(Vel.Y) > 100 then 
        if not Config.Resolver then return Vector3.zero end
        if TargetHistory[TargetPart] then
            local oldData = TargetHistory[TargetPart]
            local deltaPos = Pos - oldData.Pos
            local deltaTick = Tick - oldData.Tick
            if deltaTick > 0 then Vel = deltaPos / deltaTick end
        else
            Vel = Vector3.zero
        end
    end
    
    TargetHistory[TargetPart] = {Pos = Pos, Tick = Tick}
    for k, v in pairs(TargetHistory) do if tick() - v.Tick > 1 then TargetHistory[k] = nil end end
    
    return SafeVector(Vel)
end

local function GetOmniPrediction(TargetPart)
    local Dist = (SafeVector(TargetPart.Position) - SafeVector(Camera.CFrame.Position)).Magnitude
    local ResolvedVel = ResolverV4(TargetPart)
    
    local Ping = 0
    pcall(function() Ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000 end)
    local TravelTime = Dist / Config.BulletSpeed
    local TotalDelay = (Ping + TravelTime) * Config.Prediction
    
    local PredVel = ResolvedVel * TotalDelay
    local Drop = Vector3.new(0, (Workspace.Gravity * Config.GravityDrop * (TravelTime^2)) / 2, 0)
    return SafeVector(TargetPart.Position + PredVel + Drop)
end

local function BezierInterpolate(t, p0, p1, p2)
    local u = 1 - t; return (u^2)*p0 + 2*u*t*p1 + (t^2)*p2
end

local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local Method = getnamecallmethod()
    local Args = {...}

    if Config.SilentAim and SilentTarget and IsLocalAlive() then
        if (Method == "FindPartOnRayWithIgnoreList" or Method == "FindPartOnRayWithWhitelist" or Method == "FindPartOnRay") and Args[1] then
            local Origin = SafeVector(Args[1].Origin)
            local Direction = (GetOmniPrediction(SilentTarget) - Origin).unit * 5000
            Args[1] = Ray.new(Origin, SafeVector(Direction))
            return OldNamecall(self, unpack(Args))
        elseif Method == "Raycast" and Args[1] then
            local Origin = SafeVector(Args[1])
            local Direction = (GetOmniPrediction(SilentTarget) - Origin).unit * 5000
            Args[2] = SafeVector(Direction)
            return OldNamecall(self, unpack(Args))
        elseif Method == "FireServer" and typeof(Args[1]) == "Vector3" then
            Args[1] = GetOmniPrediction(SilentTarget)
            return OldNamecall(self, unpack(Args))
        end
    end
    
    return OldNamecall(self, ...)
end)

