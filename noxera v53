local ConfigName = "NoxeraV53_Omni.json"
local function SaveConfig()
    if writefile then
        task.spawn(function()
            local safeConfig = {}
            for k, v in pairs(Config) do if type(v) ~= "userdata" then safeConfig[k] = v end end
            pcall(function() writefile(ConfigName, HttpService:JSONEncode(safeConfig)) end)
        end)
    end
end

local function LoadConfig()
    if readfile and isfile and isfile(ConfigName) then
        pcall(function()
            local decoded = HttpService:JSONDecode(readfile(ConfigName))
            for k, v in pairs(decoded) do if Config[k] ~= nil then Config[k] = v end end
        end)
    end
end
