local function GetAimPart(C) 
    local p = C:FindFirstChild(Config.AimPart)
    if not p and Config.AimPart == "Torso" then
        p = C:FindFirstChild("UpperTorso") or C:FindFirstChild("Torso")
    end
    return p or C:FindFirstChild("HumanoidRootPart") or C:FindFirstChild("Head") 
