        else pcall(function() e.Box.Visible = false; e.Name.Visible = false; e.HP.Visible = false; e.View.Visible = false; for _, l in pairs(e.Lines) do l.Visible = false end end) end

        local AP = GetAimPart(C)
        if AP and OS then
            local APos = Camera:WorldToViewportPoint(SafeVec(AP.Position)); local D2D = (Vector2.new(APos.X, APos.Y) - Center).Magnitude
            if Config.TriggerBot and D2D <= 15 and (not Config.WallCheck or IsVisibleDeep(AP)) then TBotTarget = AP end
            
            if (Config.AimEnabled or Config.SilentAim) and D2D < cFOV and (not Config.WallCheck or IsVisibleDeep(AP)) then
                local Score = 0
                if Config.AimPriority == "Crosshair" then Score = D2D
                elseif Config.AimPriority == "Distance" then Score = D3D
                elseif Config.AimPriority == "Health" then Score = Hum.Health end
                
                if Score < BScore then
                    BScore = Score; if Config.SilentAim then SilentTarget = AP else LockedTarget = AP end; LastTargetHealth = Hum.Health
                end
            end
        end
    end

    if Config.TriggerBot and TBotTarget then ExecuteShoot() end

    if Config.TargetHUD then
        local AT = Config.SilentAim and SilentTarget or LockedTarget
        if AT and AT.Parent then
            local TP = Players:GetPlayerFromCharacter(AT.Parent)
            if TP then
                TargetHUD.Visible = true; HUD_Name.Text = "Target: " .. TP.Name
                local D = math.floor((SafeVec(Camera.CFrame.Position) - SafeVec(AT.Position)).Magnitude)
                HUD_HP.Text = "HP: " .. math.floor(LastTargetHealth) .. " | Dist: " .. D .. "m"
            end
        else TargetHUD.Visible = false end
    else TargetHUD.Visible = false end

    if Config.AimEnabled and LockedTarget and IsLocalAlive() then
        local PPos = GetOmniPrediction(LockedTarget)
        
        -- KÍCH HOẠT AUTO SHOOT VỚI AIM METHOD (KIỂM TRA GÓC NHÌN CHUẨN)
        local APos, InScreen = Camera:WorldToViewportPoint(PPos)
        if InScreen and Config.AutoShoot and not Config.TriggerBot and (not Config.WallCheck or IsVisibleDeep(LockedTarget)) then
            local aimDist = (Vector2.new(APos.X, APos.Y) - Center).Magnitude
            if aimDist < 30 then ExecuteShoot() end -- Chỉ bắn khi tâm đã ở rất gần mục tiêu
        end

        if Config.AimMethod == "Mouse" and HasMouseMoverel then
            if InScreen then
                local dX = APos.X - Center.X; local dY = APos.Y - Center.Y
                if Config.AimMode == "Rage" then mousemoverel(dX, dY)
                elseif Config.AimMode == "Bezier" then local ro = Vector2.new(math.random(-40,40), math.random(-40,40)); local bCurve = BezierInterpolate(dT * Config.Smoothness, Vector2.new(0,0), ro, Vector2.new(dX, dY)); mousemoverel(math.floor(bCurve.X), math.floor(bCurve.Y))
                else local sm = math.clamp(Config.Smoothness / 10, 0.05, 1); mousemoverel(math.floor(dX * sm), math.floor(dY * sm)) end
            end
        else
            -- BÁM TÂM CAMERA CỰC MẠNH V61
            local TCFrame = CFrame.lookAt(Camera.CFrame.Position, PPos)
            if Config.AimMode == "Rage" then 
                Camera.CFrame = TCFrame 
            else 
                -- Tăng cường Stickiness (2.5) cho CFrame
                Camera.CFrame = Camera.CFrame:Lerp(TCFrame, math.clamp(dT * (Config.Smoothness * 2.5), 0.1, 1)) 
            end
        end

        if Config.ShowTargetDot then local dp, ds = Camera:WorldToViewportPoint(PPos); pcall(function() if ds then _G.TargetDot.Position = Vector2.new(math.floor(dp.X), math.floor(dp.Y)); _G.TargetDot.Visible = true else _G.TargetDot.Visible = false end end) else pcall(function() _G.TargetDot.Visible = false end) end
    else pcall(function() _G.TargetDot.Visible = false end) end
end))

