local Tabs, TabBtns, TabHeights, TabOrder = {}, {}, {}, 0

local function SwitchTab(TName)
    for n, t in pairs(Tabs) do t.Visible = (n == TName) end
    for n, b in pairs(TabBtns) do
        if n == TName then
            TweenService:Create(b, TweenInfo.new(0.2), {BackgroundTransparency = 0, TextColor3 = Theme.Accent}):Play()
            table.insert(AccentObjects, b)
        else
            TweenService:Create(b, TweenInfo.new(0.2), {BackgroundTransparency = 1, TextColor3 = Theme.Dim}):Play()
            for i=#AccentObjects,1,-1 do if AccentObjects[i]==b then table.remove(AccentObjects,i) end end
        end
    end
end

