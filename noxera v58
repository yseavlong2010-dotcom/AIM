local Tabs, T_Btns, T_Order = {}, {}, 0

local function CreateTab(Name, Icon, Def)
    T_Order = T_Order + 1
    local B = Instance.new("TextButton", Side)
    B.LayoutOrder = T_Order; B.Size, B.BackgroundColor3, B.BackgroundTransparency = UDim2.new(1, 0, 0, 38), Theme.TabBG, Def and 0 or 1
    B.Text, B.TextColor3, B.Font, B.TextSize, B.TextXAlignment = "   " .. Icon .. " " .. Name, Def and Theme.Accent or Theme.Dim, Enum.Font.GothamBold, 12, Enum.TextXAlignment.Left
    Instance.new("UICorner", B).CornerRadius = UDim.new(0, 4); if Def then table.insert(AccentObjects, B) end
    Side.CanvasSize = UDim2.new(0, 0, 0, T_Order * 42 + 10)

    local C = Instance.new("ScrollingFrame", Cont)
    C.Size, C.Position, C.BackgroundTransparency, C.ScrollBarThickness, C.Visible = UDim2.new(1, -16, 1, -16), UDim2.new(0, 8, 0, 8), 1, 2, Def
    local L = Instance.new("UIListLayout", C); L.Padding = UDim.new(0, 6); L.SortOrder = Enum.SortOrder.LayoutOrder
    
    table.insert(T_Btns, B); Tabs[Name] = {F = C, L = L, Items = 0}

    B.MouseButton1Click:Connect(function()
        for _, b in pairs(T_Btns) do TweenService:Create(b, TweenInfo.new(0.2), {BackgroundTransparency = 1, TextColor3 = Theme.Dim}):Play(); for i=#AccentObjects,1,-1 do if AccentObjects[i]==b then table.remove(AccentObjects,i) end end end
        for _, c in pairs(Tabs) do c.F.Visible = false end
        TweenService:Create(B, TweenInfo.new(0.2), {BackgroundTransparency = 0, TextColor3 = Theme.Accent}):Play(); table.insert(AccentObjects, B); C.Visible = true
    end)
    return Name
end

local function AddCanvas(T_Name, Y) Tabs[T_Name].Items = Tabs[T_Name].Items + 1; Tabs[T_Name].F.CanvasSize = UDim2.new(0, 0, 0, Tabs[T_Name].Items * Y + (Tabs[T_Name].Items * 6) + 10) end

local function CreateToggle(T_Name, Txt, Key, Cb)
    local F = Instance.new("TextButton", Tabs[T_Name].F); F.Size, F.BackgroundColor3, F.Text = UDim2.new(1, 0, 0, 40), Theme.BG, ""; Instance.new("UICorner", F).CornerRadius = UDim.new(0, 4)
    local L = Instance.new("TextLabel", F); L.Size, L.Position, L.BackgroundTransparency, L.Text, L.TextColor3, L.Font, L.TextSize, L.TextXAlignment = UDim2.new(1, -60, 1, 0), UDim2.new(0, 10, 0, 0), 1, Txt, Theme.Text, Enum.Font.GothamSemibold, 12, Enum.TextXAlignment.Left
    local SB = Instance.new("Frame", F); SB.Size, SB.Position, SB.BackgroundColor3 = UDim2.new(0, 34, 0, 16), UDim2.new(1, -44, 0.5, -8), Config[Key] and Theme.Accent or Color3.fromRGB(50, 50, 55); Instance.new("UICorner", SB).CornerRadius = UDim.new(1, 0)
    local SK = Instance.new("Frame", SB); SK.Size, SK.Position, SK.BackgroundColor3 = UDim2.new(0, 12, 0, 12), Config[Key] and UDim2.new(1, -14, 0.5, -6) or UDim2.new(0, 2, 0.5, -6), Color3.new(1,1,1); Instance.new("UICorner", SK).CornerRadius = UDim.new(1, 0)
    if Config[Key] then table.insert(AccentObjects, SB) end
    F.MouseButton1Click:Connect(function()
        Config[Key] = not Config[Key]; SaveConfig()
        if Config[Key] then table.insert(AccentObjects, SB) else for i=#AccentObjects,1,-1 do if AccentObjects[i]==SB then table.remove(AccentObjects,i) end end end
        TweenService:Create(SB, TweenInfo.new(0.2), {BackgroundColor3 = Config[Key] and Theme.Accent or Color3.fromRGB(50, 50, 55)}):Play()
        TweenService:Create(SK, TweenInfo.new(0.2), {Position = Config[Key] and UDim2.new(1, -14, 0.5, -6) or UDim2.new(0, 2, 0.5, -6)}):Play()
        if Cb then task.spawn(Cb, Config[Key]) end
        -- Special Sync for AimEnabled Toggle
        if Key == "AimEnabled" and QuickBtnFrame then
            TweenService:Create(QB_Stroke, TweenInfo.new(0.3), {Color = Config.AimEnabled and Color3.fromRGB(0, 255, 100) or Theme.AccentOff}):Play()
        end
    end); AddCanvas(T_Name, 40)
end

local function CreateSlider(T_Name, Txt, Key, Min, Max, Step)
    local F = Instance.new("Frame", Tabs[T_Name].F); F.Size, F.BackgroundColor3 = UDim2.new(1, 0, 0, 50), Theme.BG; Instance.new("UICorner", F).CornerRadius = UDim.new(0, 4)
    local L = Instance.new("TextLabel", F); L.Size, L.Position, L.BackgroundTransparency, L.Text, L.TextColor3, L.Font, L.TextSize, L.TextXAlignment = UDim2.new(1, -20, 0, 20), UDim2.new(0, 10, 0, 4), 1, Txt .. ": " .. Config[Key], Theme.Text, Enum.Font.GothamSemibold, 11, Enum.TextXAlignment.Left
    local SB = Instance.new("TextButton", F); SB.Size, SB.Position, SB.BackgroundColor3, SB.Text = UDim2.new(1, -20, 0, 6), UDim2.new(0, 10, 0, 32), Color3.fromRGB(40, 40, 45), ""; Instance.new("UICorner", SB).CornerRadius = UDim.new(1, 0)
    local Fill = Instance.new("Frame", SB); Fill.Size, Fill.BackgroundColor3 = UDim2.new((Config[Key] - Min) / (Max - Min), 0, 1, 0), Theme.Accent; Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0); table.insert(AccentObjects, Fill)
    local drag = false
    local function Upd(i) local X = math.clamp((i.Position.X - SB.AbsolutePosition.X) / SB.AbsoluteSize.X, 0, 1); local V = math.floor(((Min + (Max - Min) * X) / Step) + 0.5) * Step; Config[Key] = V; Fill.Size = UDim2.new(X, 0, 1, 0); L.Text = Txt .. ": " .. V; if Key == "CameraFOV" then Camera.FieldOfView = V elseif Key == "ClockTime" then Lighting.ClockTime = V end end
    SB.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then drag = true; Upd(i) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then drag = false; SaveConfig() end end)
    UserInputService.InputChanged:Connect(function(i) if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then Upd(i) end end)
    AddCanvas(T_Name, 50)
end

local function CreateDropdown(T_Name, Txt, Key, Opts)
    local F = Instance.new("TextButton", Tabs[T_Name].F); F.Size, F.BackgroundColor3, F.Text = UDim2.new(1, 0, 0, 40), Theme.BG, ""; Instance.new("UICorner", F).CornerRadius = UDim.new(0, 4)
    local L = Instance.new("TextLabel", F); L.Size, L.Position, L.BackgroundTransparency, L.Text, L.TextColor3, L.Font, L.TextSize, L.TextXAlignment = UDim2.new(1, -110, 1, 0), UDim2.new(0, 10, 0, 0), 1, Txt, Theme.Text, Enum.Font.GothamSemibold, 12, Enum.TextXAlignment.Left
    local VL = Instance.new("TextLabel", F); VL.Size, VL.Position, VL.BackgroundTransparency, VL.Text, VL.TextColor3, VL.Font, VL.TextSize, VL.TextXAlignment = UDim2.new(0, 100, 1, 0), UDim2.new(1, -110, 0, 0), 1, Config[Key], Theme.Accent, Enum.Font.GothamBold, 12, Enum.TextXAlignment.Right; table.insert(AccentObjects, VL)
    local idx = 1; for i, v in ipairs(Opts) do if v == Config[Key] then idx = i break end end
    F.MouseButton1Click:Connect(function() idx = idx + 1; if idx > #Opts then idx = 1 end; Config[Key] = Opts[idx]; VL.Text = Config[Key]; SaveConfig() end)
    AddCanvas(T_Name, 40)
end

