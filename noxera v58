local function IsLocalAlive()
    if not LocalPlayer or not LocalPlayer.Character then return false end
    local Hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    return Hum and Hum.Health > 0 and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") ~= nil
end

local function TriggerHitFeedback()
    if Config.HitSound then task.spawn(function() HitAudio:Play() end) end
    if Config.HitMarker then HM_Alpha = 1 end
end

local function ExecuteShoot()
    if not IsLocalAlive() or UserInputService:GetFocusedTextBox() then return end
    if tick() - LastShootTick > Config.ShootDelay then
        LastShootTick = tick(); TriggerHitFeedback()
        task.spawn(function()
            if Config.ShootMethod == "Tool" then local T = LocalPlayer.Character:FindFirstChildOfClass("Tool"); if T then T:Activate() end
            elseif Config.ShootMethod == "Mouse API" and HasMouseMoverel then if mouse1click then mouse1click() elseif mouse1press then mouse1press() task.wait(0.01) mouse1release() end
            elseif Config.ShootMethod == "VIM" then local c = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2); pcall(function() VIM:SendMouseButtonEvent(c.X, c.Y, 0, true, game, 1); task.wait(0.01); VIM:SendMouseButtonEvent(c.X, c.Y, 0, false, game, 1) end) end
        end)
    end
end

local function IsNaN(v) return v ~= v end
local function SafeVec(v)
    if not v or typeof(v) ~= "Vector3" then return Vector3.zero end
    if IsNaN(v.X) or IsNaN(v.Y) or IsNaN(v.Z) then return Vector3.zero end
    if math.abs(v.X) == math.huge or math.abs(v.Y) == math.huge or math.abs(v.Z) == math.huge then return Vector3.zero end
    return v
end

local function IsValidTarget(P)
    if P == LocalPlayer then return false end
    local C = P.Character; if not C or not C:IsDescendantOf(Workspace) then return false end 
    local H = C:FindFirstChildOfClass("Humanoid"); if not H or H.Health <= 0 then return false end
    if Config.TeamCheck and LocalPlayer.Team and P.Team and LocalPlayer.Team == P.Team then return false end
    if C:FindFirstChild("ForceField") then return false end
    return true
end

local function GetAimPart(C) local p = C:FindFirstChild(Config.AimPart); return p or C:FindFirstChild("HumanoidRootPart") or C:FindFirstChild("Torso") end

local function IsVisibleDeep(TPart)
    local O = SafeVec(Camera.CFrame.Position); local D = SafeVec(TPart.Position - O)
    RayParams.FilterDescendantsInstances = {LocalPlayer.Character, Camera}; local R = Workspace:Raycast(O, D, RayParams)
    if not R then return true end
    if R.Instance:IsDescendantOf(TPart.Parent) then return true end
    if R.Instance.Transparency > 0.5 or not R.Instance.CanCollide then return true end
    return false
end

local function DrawOOFArrow(TPos, Obj, Col)
    if not Obj or Obj.Visible == nil then return end
    local OS = Camera.CFrame:PointToObjectSpace(SafeVec(TPos)); local Ang = math.atan2(OS.X, OS.Z)
    if IsNaN(Ang) then return end 
    local CX, CY = math.floor(Camera.ViewportSize.X/2), math.floor(Camera.ViewportSize.Y/2)
    pcall(function()
        Obj.PointA = Vector2.new(math.floor(CX + math.sin(Ang) * 150), math.floor(CY + math.cos(Ang) * 150))
        Obj.PointB = Vector2.new(math.floor(CX + math.sin(Ang + 0.15) * 130), math.floor(CY + math.cos(Ang + 0.15) * 130))
        Obj.PointC = Vector2.new(math.floor(CX + math.sin(Ang - 0.15) * 130), math.floor(CY + math.cos(Ang - 0.15) * 130))
        Obj.Color = Col; Obj.Visible = true
    end)
end

local TargetHistory = {}
local function ResolverV7(TPart)
    local V = TPart.Velocity; local P = SafeVec(TPart.Position); local T = tick()
    if IsNaN(V.X) or V.Magnitude > 300 or math.abs(V.Y) > 100 then 
        if not Config.Resolver then return Vector3.zero end
        if TargetHistory[TPart] then local dt = T - TargetHistory[TPart].T; if dt > 0 then V = (P - TargetHistory[TPart].P) / dt end else V = Vector3.zero end
    end
    TargetHistory[TPart] = {P = P, T = T}
    for k, v in pairs(TargetHistory) do if tick() - v.T > 1 then TargetHistory[k] = nil end end
    return SafeVec(V)
end

local function GetOmniPrediction(TPart)
    local P1 = SafeVec(TPart.Position); local P2 = SafeVec(Camera.CFrame.Position)
    local D = (P1 - P2).Magnitude
    local RV = ResolverV7(TPart); local P = 0; pcall(function() P = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000 end)
    local TT = D / Config.BulletSpeed; local TD = (P + TT) * Config.Prediction
    return SafeVec(P1 + (RV * TD) + Vector3.new(0, (Workspace.Gravity * Config.GravityDrop * (TT^2)) / 2, 0))
end

local function BezierInterpolate(t, p0, p1, p2) local u = 1 - t; return (u^2)*p0 + 2*u*t*p1 + (t^2)*p2 end

local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local Method = getnamecallmethod(); local Args = {...}
    if Config.SilentAim and SilentTarget and IsLocalAlive() then
        if (Method == "FindPartOnRayWithIgnoreList" or Method == "FindPartOnRayWithWhitelist" or Method == "FindPartOnRay") and Args[1] then
            Args[1] = Ray.new(SafeVec(Args[1].Origin), SafeVec((GetOmniPrediction(SilentTarget) - SafeVec(Args[1].Origin)).unit * 5000))
            return OldNamecall(self, unpack(Args))
        elseif Method == "Raycast" and Args[1] then
            Args[2] = SafeVec((GetOmniPrediction(SilentTarget) - SafeVec(Args[1])).unit * 5000)
            return OldNamecall(self, unpack(Args))
        elseif Method == "FireServer" and typeof(Args[1]) == "Vector3" then
            Args[1] = GetOmniPrediction(SilentTarget)
            return OldNamecall(self, unpack(Args))
        end
    end
    return OldNamecall(self, ...)
end)

