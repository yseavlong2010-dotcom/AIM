local ConfigName = "NoxeraV58_Warlord.json"
local function SaveConfig()
    if writefile then task.spawn(function() local s = {} for k,v in pairs(Config) do if type(v)~="userdata" then s[k]=v end end pcall(function() writefile(ConfigName, HttpService:JSONEncode(s)) end) end) end
end
local function LoadConfig()
    if readfile and isfile and isfile(ConfigName) then 
        local success = pcall(function() 
            local d = HttpService:JSONDecode(readfile(ConfigName)) 
            for k,v in pairs(d) do if Config[k]~=nil then Config[k]=v end end 
        end)
        return success
    end
    return false
end

