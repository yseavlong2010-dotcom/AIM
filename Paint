    State.Pos1 = GetPlayerFootPosition()
    if State.Pos1 then
        BtnPos1.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        BtnPos1.Text = "✅ Đã lưu Góc 1"
        StatusLbl.Text = "Đã lưu vị trí 1 thành công!"
    end
end)

