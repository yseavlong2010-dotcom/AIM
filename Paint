local function SendNotification(title, text, duration)
    local notif = Instance.new("Frame", NotifyContainer)
    notif.Size = UDim2.new(1, 0, 0, 60)
    notif.Position = UDim2.new(1, 50, 1, 0) -- Giấu ở ngoài màn hình
    notif.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    Instance.new("UICorner", notif).CornerRadius = UDim.new(0, 8)
    
    local glow = Instance.new("UIStroke", notif)
    glow.Color = Color3.fromRGB(0, 255, 150)
    glow.Thickness = 2
    
    local titleLbl = Instance.new("TextLabel", notif)
    titleLbl.Size = UDim2.new(1, -10, 0, 25)
    titleLbl.Position = UDim2.new(0, 10, 0, 5)
    titleLbl.Text = title
    titleLbl.TextColor3 = Color3.fromRGB(255, 215, 0)
    titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.BackgroundTransparency = 1
    
    local descLbl = Instance.new("TextLabel", notif)
    descLbl.Size = UDim2.new(1, -10, 0, 25)
    descLbl.Position = UDim2.new(0, 10, 0, 30)
    descLbl.Text = text
    descLbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    descLbl.Font = Enum.Font.Gotham
    descLbl.TextXAlignment = Enum.TextXAlignment.Left
    descLbl.BackgroundTransparency = 1
    
    -- Sắp xếp vị trí các thông báo cũ
    for i, child in ipairs(NotifyContainer:GetChildren()) do
        if child ~= notif then
            TweenService:Create(child, TweenInfo.new(0.3), {Position = child.Position - UDim2.new(0,0,0,70)}):Play()
        end
    end
    
    -- Hiệu ứng trượt vào
    TweenService:Create(notif, TweenInfo.new(0.4, Enum.EasingStyle.Back), {Position = UDim2.new(0, 0, 1, -70)}):Play()
    
    task.delay(duration or 3, function()
        local outTween = TweenService:Create(notif, TweenInfo.new(0.3), {Position = UDim2.new(1, 50, notif.Position.Y.Scale, notif.Position.Y.Offset)})
        outTween:Play()
        outTween.Completed:Connect(function() notif:Destroy() end)
    end)
end

