-- ==========================================
-- 3. AUTO-EQUIP VÀ CORE VẼ TRỤC X-Z (MẶT ĐẤT)
-- ==========================================
local function EnsureToolEquipped()
    local char = LocalPlayer.Character
    if not char then return false end
    if char:FindFirstChildOfClass("Tool") then return true end
    
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack and backpack:FindFirstChildOfClass("Tool") then
        char.Humanoid:EquipTool(backpack:FindFirstChildOfClass("Tool"))
        return true
    end
    return false
end

local function StartFloorPainting()
    if not State.Pos1 or not State.Pos2 then
        StatusLbl.Text = "⚠️ Lỗi: Bạn phải đi bộ và Set đủ 2 góc trước!"
        return
    end

    State.IsDrawing = true
    ActionBtn.Text = "⏹ ĐANG VẼ... (BẤM ĐỂ DỪNG)"
    ActionBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)

    if not EnsureToolEquipped() then
        StatusLbl.Text = "⚠️ Đang tự động cầm công cụ vẽ..."
        task.wait(0.5)
    end

    -- Dữ liệu giả lập 40x40 ảnh
    local mockData = {}
    for y = 1, 40 do
        for x = 1, 40 do table.insert(mockData, {X=x, Y=y, R=255, G=255, B=255}) end
    end

    task.spawn(function()
        for idx, pixel in ipairs(mockData) do
            if not State.IsDrawing then break end
            
            -- TOÁN HỌC TRỤC X-Z CHO MẶT ĐẤT
            local percentX = pixel.X / 40
            local percentY = pixel.Y / 40
            
            -- Nội suy trục X và trục Z, giữ nguyên độ cao Y của mặt đất
            local worldX = State.Pos1.X + (percentX * (State.Pos2.X - State.Pos1.X))
            local worldZ = State.Pos1.Z + (percentY * (State.Pos2.Z - State.Pos1.Z))
            local worldY = State.Pos1.Y 
            
            local targetFloorPos = Vector3.new(worldX, worldY, worldZ)
            
            -- BỌC PCALL ĐỂ CHỐNG CRASH GAME (SAFE FIRE)
            local success, err = pcall(function()
                -- [!] DÀNH CHO SẾP: Thay đổi tên Event ở dòng dưới cho khớp với Map
                -- game.ReplicatedStorage.PaintFloorEvent:FireServer(targetFloorPos, Color3.fromRGB(pixel.R, pixel.G, pixel.B))
            end)
            
            StatusLbl.Text = string.format("Đang vẽ chấm màu thứ: %d / %d", idx, #mockData)
            
            if idx % 10 == 0 then task.wait(State.DrawDelay) end
        end
        
        State.IsDrawing = false
        ActionBtn.Text = "▶ BẮT ĐẦU VẼ XUỐNG ĐẤT"
        ActionBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
        StatusLbl.Text = "Hoàn tất bức tranh!"
    end)
end

ActionBtn.MouseButton1Click:Connect(function()
    if not State.IsDrawing then StartFloorPainting() else State.IsDrawing = false end
end)
