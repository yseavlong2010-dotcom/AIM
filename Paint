            if not State.IsDrawing then break end
            
            -- TÍNH TOÁN SMART DELAY DỰA TRÊN PING
            local currentPing = LocalPlayer:GetNetworkPing() * 1000 -- Đổi ra ms
            local dynamicDelay = currentPing > 150 and 0.05 or 0.02
            
            local success, err = pcall(function()
                -- [ENGINE CODE NHƯ BẢN V5 ĐÃ CẤU HÌNH Ở ĐÂY]
            end)
            
            if idx % 10 == 0 then 
                task.wait(dynamicDelay) -- Độ trễ thông minh
