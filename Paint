local function SwitchMode(mode)
    State.CurrentMode = mode
    Btn2D.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    Btn3DWall.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    Btn3DFloor.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    FloorBtn1.Visible = false
    FloorBtn2.Visible = false
    
    if mode == "2D" then
        Btn2D.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
        SendNotification("Chế độ 2D", "Đã bật chế độ vẽ Canvas cơ bản.", 2)
    elseif mode == "3D_Wall" then
        Btn3DWall.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
        SendNotification("Chế độ Tường", "Chạm vào tường 3D để khóa mục tiêu.", 3)
    elseif mode == "3D_Floor" then
        Btn3DFloor.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
        FloorBtn1.Visible = true
        FloorBtn2.Visible = true
        SendNotification("Chế độ Mặt Đất", "Hãy đi bộ và lưu tọa độ 2 góc bảng vẽ.", 3)
    end
end

Btn2D.MouseButton1Click:Connect(function() SwitchMode("2D") end)
Btn3DWall.MouseButton1Click:Connect(function() SwitchMode("3D_Wall") end)
Btn3DFloor.MouseButton1Click:Connect(function() SwitchMode("3D_Floor") end)

local function GetPlayerFootPosition()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        return char.HumanoidRootPart.Position - Vector3.new(0, 3, 0)
    end
    return nil
end

FloorBtn1.MouseButton1Click:Connect(function()
    State.FloorPos1 = GetPlayerFootPosition()
    if State.FloorPos1 then SendNotification("Thành công", "Đã lưu tọa độ Chân 1", 2) end
end)

FloorBtn2.MouseButton1Click:Connect(function()
    State.FloorPos2 = GetPlayerFootPosition()
    if State.FloorPos2 then SendNotification("Thành công", "Đã lưu tọa độ Chân 2", 2) end
end)

UserInputService.TouchStarted:Connect(function(touch, processed)
    if processed or State.CurrentMode ~= "3D_Wall" then return end
    local ray = Camera:ViewportPointToRay(touch.Position.X, touch.Position.Y)
    local result = Workspace:Raycast(ray.Origin, ray.Direction * 500)
    if result and result.Instance:IsA("BasePart") then
        State.TargetWall = result.Instance
        SendNotification("Đã Khóa Tường", result.Instance.Name, 2)
    end
end)

