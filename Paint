-- 2. LOGIC LẤY TỌA ĐỘ TỪ CHÂN NHÂN VẬT
-- ==========================================
local function GetPlayerFootPosition()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        -- Lấy vị trí tâm nhân vật, trừ đi 3 studs trục Y để lấy đúng mặt đất ngay dưới chân
        return char.HumanoidRootPart.Position - Vector3.new(0, 3, 0)
    end
    return nil
end

