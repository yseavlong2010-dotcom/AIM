local function GetESP(Player)
    if not ESP_Cache[Player] then
        ESP_Cache[Player] = { Box = Drawing.new("Square"), Name = Drawing.new("Text"), HP = Drawing.new("Square"), Tracer = Drawing.new("Line"), Dist = Drawing.new("Text") }
        local e = ESP_Cache[Player]
        e.Box.Color = Color3.fromRGB(255, 255, 255); e.Box.Thickness = 1.5; e.Box.Filled = false
        e.Name.Color = Color3.fromRGB(255, 255, 255); e.Name.Size = 14; e.Name.Center = true; e.Name.Outline = true
        e.HP.Color = Color3.fromRGB(0, 255, 0); e.HP.Filled = true
        e.Tracer.Color = Color3.fromRGB(80, 150, 255); e.Tracer.Thickness = 1.5
        e.Dist.Color = Color3.fromRGB(200, 200, 200); e.Dist.Size = 12; e.Dist.Center = true; e.Dist.Outline = true
    end
    return ESP_Cache[Player]
end

local function HideESP(Player)
    if ESP_Cache[Player] then
        local e = ESP_Cache[Player]
        e.Box.Visible = false; e.Name.Visible = false; e.HP.Visible = false; e.Tracer.Visible = false; e.Dist.Visible = false
    end
    if Player.Character and Player.Character:FindFirstChild("NoxChams") then Player.Character.NoxChams:Destroy() end
end

--=============================================================================
-- [MAIN RENDER LOOP - TÁCH LUỒNG CHUẨN]
--=============================================================================
RunService.RenderStepped:Connect(function(deltaTime)
    if not Runtime.EngineStarted then return end 

    pcall(function()
        if Runtime.Watermark and _G.NoxeraWatermark then
            _G.NoxeraWatermark.Visible = true; _G.NoxeraWatermark.Text = " NOXERA APEX | FPS: " .. math.floor(1 / deltaTime) .. " | Ping: " .. math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()) .. "ms "
        elseif _G.NoxeraWatermark then _G.NoxeraWatermark.Visible = false end

        -- 1. PHYSICS & MOVEMENT
        local Char = LocalPlayer.Character
        local Hum = Char and Char:FindFirstChildOfClass("Humanoid")
        local HRP = Char and Char:FindFirstChild("HumanoidRootPart")

        if Hum and HRP then
            if Runtime.CFrameSpeed and Hum.MoveDirection.Magnitude > 0 then HRP.CFrame = HRP.CFrame + (Hum.MoveDirection * Runtime.SpeedValue * deltaTime * 10) end
            if Runtime.Desync then
                local oldVel = HRP.Velocity
                HRP.Velocity = Vector3.new(math.random(-500,500), math.random(-50,50), math.random(-500,500))
                RunService.RenderStepped:Wait()
                HRP.Velocity = oldVel
            end
            if Runtime.FlingAura then
                local oldRot = HRP.RotVelocity; HRP.RotVelocity = Vector3.new(0, 5000, 0)
                RunService.RenderStepped:Wait(); HRP.RotVelocity = oldRot
            end
            if Runtime.MacroEnabled then
                local Tool = Char:FindFirstChildOfClass("Tool")
                if Tool and Tool.Name:lower():match("wallet") and Hum.MoveDirection.Magnitude > 0 then
                    HRP.Velocity = Vector3.new(Hum.MoveDirection.X * (Runtime.MacroSpeed * 20), HRP.Velocity.Y, Hum.MoveDirection.Z * (Runtime.MacroSpeed * 20))
                end
            end
        end
        if Runtime.NoClip and Char then for _, v in pairs(Char:GetDescendants()) do if v:IsA("BasePart") and v.CanCollide then v.CanCollide = false end end end
    end)

    pcall(function()
        -- 2. TRIGGERBOT
        if Runtime.AutoShoot and tick() - LastShootTick >= CustomConfig.ShootDelay then
            local Char = LocalPlayer.Character
            local rayParams = RaycastParams.new()
            rayParams.FilterType = Enum.RaycastFilterType.Exclude
            rayParams.FilterDescendantsInstances = {Char, Camera, Workspace:FindFirstChild("Ignored"), Workspace:FindFirstChild("Filter")}
            local result = Workspace:Raycast(Camera.CFrame.Position, Camera.CFrame.LookVector * 1000, rayParams)
            if result and result.Instance then
                local hitModel = result.Instance:FindFirstAncestorOfClass("Model")
                if hitModel and hitModel:FindFirstChild("Humanoid") and not IsKnocked(hitModel) then
                    local targetPlayer = Players:GetPlayerFromCharacter(hitModel)
                    if targetPlayer and targetPlayer ~= LocalPlayer and not IsTeamMate(targetPlayer) then
                        local Tool = Char:FindFirstChildOfClass("Tool")
                        if Tool then Tool:Activate(); LastShootTick = tick() end
                    end
                end
            end
        end
    end)

    pcall(function()
        -- 3. ESP & SMART TARGET FINDING
        local ScreenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        local ScreenBottom = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
        
        FOVCircle.Position = ScreenCenter; FOVCircle.Radius = Runtime.AimFOV; FOVCircle.Visible = Runtime.AimEnabled
        if Runtime.CustomCrosshair then
            CrossX.Visible = true; CrossY.Visible = true
            CrossX.From = Vector2.new(ScreenCenter.X - 8, ScreenCenter.Y); CrossX.To = Vector2.new(ScreenCenter.X + 8, ScreenCenter.Y)
            CrossY.From = Vector2.new(ScreenCenter.X, ScreenCenter.Y - 8); CrossY.To = Vector2.new(ScreenCenter.X, ScreenCenter.Y + 8)
        else CrossX.Visible = false; CrossY.Visible = false end

        -- KIỂM TRA MỤC TIÊU CŨ (THOÁT KHÓA KHẨN CẤP NẾU VUỐT MẠNH HOẶC CHẾT)
        if LockedTarget then
            if not IsValidTarget(LockedTarget) then 
                LockedTarget = nil 
            else
                local Pos, OnScreen = Camera:WorldToViewportPoint(LockedTarget.Position)
                if OnScreen then
                    local DistToCenter = (Vector2.new(Pos.X, Pos.Y) - ScreenCenter).Magnitude
                    -- Breakaway: Vuốt camera quá mạnh khiến địch văng khỏi FOV (x 1.5 để chừa khoảng sai số)
                    if DistToCenter > (Runtime.AimFOV * 1.5) or (Runtime.WallCheck and not IsVisible(LockedTarget)) then
                        LockedTarget = nil
                    end
                else LockedTarget = nil end
            end
        end

        local BestTarget = nil
        local BestScore = math.huge 

        for _, Player in ipairs(Players:GetPlayers()) do
            if Player == LocalPlayer then continue end
            if IsTeamMate(Player) then HideESP(Player); continue end

            local EChar = Player.Character
            if not IsValidTarget(EChar and EChar:FindFirstChild("HumanoidRootPart")) then HideESP(Player); continue end

            local EHum = EChar:FindFirstChild("Humanoid")
            local EHRP = EChar:FindFirstChild("HumanoidRootPart")
            local EHead = EChar:FindFirstChild("Head")

            if Runtime.SilentAim then
                EHRP.Size = Vector3.new(CustomConfig.HitboxSize, CustomConfig.HitboxSize, CustomConfig.HitboxSize)
                EHRP.Transparency = 1; EHRP.CanCollide = false
            end

            if Runtime.ESPChams then
                if not EChar:FindFirstChild("NoxChams") then
                    local hl = Instance.new("Highlight", EChar)
                    hl.Name = "NoxChams"; hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                end
                EChar.NoxChams.FillColor = (LockedTarget and LockedTarget.Parent == EChar) and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(255, 50, 50)
            else
                if EChar:FindFirstChild("NoxChams") then EChar.NoxChams:Destroy() end
            end

            local DistToPlayer = math.floor((Camera.CFrame.Position - EHRP.Position).Magnitude)
            if DistToPlayer > Runtime.MaxRender then HideESP(Player); continue end

            local Pos, OnScreen = Camera:WorldToViewportPoint(EHRP.Position)
            local isVis = IsVisible(EHRP)

            -- VISCHECK ESP
            if OnScreen and (Runtime.ESPBox or Runtime.ESPName or Runtime.ESPHP or Runtime.ESPTracer or Runtime.ESPDistance) then
                local TopPos, TopVis = Camera:WorldToViewportPoint(EHead.Position + Vector3.new(0, 0.5, 0))
                local BotPos, BotVis = Camera:WorldToViewportPoint(EHRP.Position - Vector3.new(0, 3, 0))

                if TopVis and BotVis then
                    local BoxH = math.abs(TopPos.Y - BotPos.Y); local BoxW = BoxH * 0.55; local BoxPos = Vector2.new(TopPos.X - BoxW / 2, TopPos.Y)
                    local ESP = GetESP(Player)
                    local espColor = isVis and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(255, 50, 50)
                    
                    ESP.Box.Size = Vector2.new(BoxW, BoxH); ESP.Box.Position = BoxPos; ESP.Box.Visible = Runtime.ESPBox; ESP.Box.Color = espColor
                    ESP.Name.Text = Player.Name; ESP.Name.Position = Vector2.new(TopPos.X, TopPos.Y - 15); ESP.Name.Visible = Runtime.ESPName; ESP.Name.Color = espColor
                    local HPRatio = math.clamp(EHum.Health / EHum.MaxHealth, 0, 1)
                    ESP.HP.Size = Vector2.new(2, BoxH * HPRatio); ESP.HP.Position = Vector2.new(BoxPos.X - 5, TopPos.Y + BoxH - (BoxH * HPRatio))
                    ESP.HP.Color = Color3.fromRGB(255 - (255 * HPRatio), 255 * HPRatio, 0); ESP.HP.Visible = Runtime.ESPHP
                    ESP.Tracer.From = ScreenBottom; ESP.Tracer.To = Vector2.new(BotPos.X, BotPos.Y); ESP.Tracer.Visible = Runtime.ESPTracer; ESP.Tracer.Color = espColor
                    ESP.Dist.Text = "[" .. DistToPlayer .. "m]"; ESP.Dist.Position = Vector2.new(TopPos.X, BotPos.Y + 5); ESP.Dist.Visible = Runtime.ESPDistance
                else HideESP(Player) end
            else HideESP(Player) end

            -- THUẬT TOÁN AI: CLOSE-QUARTERS & FIRST-PERSON OPTIMIZED
            local AimPart = GetActualAimPart(EChar)
            if AimPart and Runtime.AimEnabled and not LockedTarget and OnScreen then
                local AimPos = Camera:WorldToViewportPoint(AimPart.Position)
                local DistToCenter = (Vector2.new(AimPos.X, AimPos.Y) - ScreenCenter).Magnitude
                
                if DistToCenter <= Runtime.AimFOV then
                    if not Runtime.WallCheck or isVis then
                        local Dist3D = (Camera.CFrame.Position - AimPart.Position).Magnitude
                        local Score = DistToCenter
                        
                        -- Cận Chiến & Nằm Phía Trước Camera: Ưu tiên tối đa!
                        -- Nếu dưới 35 studs, Score cực nhỏ, buộc Camera bắt thằng này thay vì thằng ở giữa tâm nhưng xa xôi.
                        if Dist3D < CustomConfig.CloseRange then
                            Score = Score * 0.1 
                        else
                            Score = (DistToCenter * 0.6) + (Dist3D * 0.4)
                        end

                        if Score < BestScore then
                            BestScore = Score
                            BestTarget = AimPart
                        end
                    end
                end
            end
        end

        if BestTarget and not LockedTarget then LockedTarget = BestTarget end

        -- 4. THỰC THI CAMERA AIM
        if Runtime.AimEnabled and LockedTarget then
            local ResolvedVel = ResolveVelocity(Players:GetPlayerFromCharacter(LockedTarget.Parent), LockedTarget.Velocity)
            local TargetPos = LockedTarget.Position + (ResolvedVel * Runtime.Prediction)
            local TargetCFrame = CFrame.lookAt(Camera.CFrame.Position, TargetPos)
            
            if Runtime.AimMode == "Rage" then Camera.CFrame = TargetCFrame
            else Camera.CFrame = Camera.CFrame:Lerp(TargetCFrame, Runtime.Smoothness) end

            if Runtime.ShowTargetDot then
                local tPos, tOnScreen = Camera:WorldToViewportPoint(TargetPos)
                if tOnScreen then TargetDot.Position = Vector2.new(tPos.X, tPos.Y); TargetDot.Visible = true else TargetDot.Visible = false end
            else TargetDot.Visible = false end
        else TargetDot.Visible = false end
    end)
end)
