end

local function SafeVector(v)
    if not v then return Vector3.zero end
    if v.X ~= v.X or math.abs(v.X) == math.huge then return Vector3.zero end
    return v
end

local function IsValidTarget(P)
    if P == LocalPlayer then return false end
    local C = P.Character; if not C or not C:IsDescendantOf(Workspace) then return false end 
    local H = C:FindFirstChildOfClass("Humanoid"); if not H or H.Health <= 0 then return false end
    if Config.TeamCheck and LocalPlayer.Team and P.Team and LocalPlayer.Team == P.Team then return false end
    if C:FindFirstChild("ForceField") then return false end
    return true
end

local function GetAimPart(C) local p = C:FindFirstChild(Config.AimPart); return p or C:FindFirstChild("HumanoidRootPart") or C:FindFirstChild("Torso") end

local function IsVisibleDeep(TPart)
    local O = SafeVector(Camera.CFrame.Position); local D = SafeVector(TPart.Position - O)
    RayParams.FilterDescendantsInstances = {LocalPlayer.Character, Camera}; local R = Workspace:Raycast(O, D, RayParams)
    if not R then return true end
    if R.Instance:IsDescendantOf(TPart.Parent) then return true end
    if R.Instance.Transparency > 0.5 or not R.Instance.CanCollide then return true end
    return false
end

local function DrawOOFArrow(TPos, Obj, Col)
    if not Obj or Obj.Visible == nil then return end
    local OS = Camera.CFrame:PointToObjectSpace(SafeVector(TPos)); local Ang = math.atan2(OS.X, OS.Z)
    if Ang ~= Ang then return end 
    local CX, CY = math.floor(Camera.ViewportSize.X/2), math.floor(Camera.ViewportSize.Y/2)
    pcall(function()
        Obj.PointA = Vector2.new(math.floor(CX + math.sin(Ang) * 150), math.floor(CY + math.cos(Ang) * 150))
        Obj.PointB = Vector2.new(math.floor(CX + math.sin(Ang + 0.15) * 130), math.floor(CY + math.cos(Ang + 0.15) * 130))
        Obj.PointC = Vector2.new(math.floor(CX + math.sin(Ang - 0.15) * 130), math.floor(CY + math.cos(Ang - 0.15) * 130))
        Obj.Color = Col; Obj.Visible = true
    end)
end

local TargetHistory = {}
local function ResolverV6(TPart)
    local V = TPart.Velocity; local P = SafeVector(TPart.Position); local T = tick()
    if V.X ~= V.X or V.Magnitude > 300 or math.abs(V.Y) > 100 then 
        if not Config.Resolver then return Vector3.zero end
        if TargetHistory[TPart] then local dt = T - TargetHistory[TPart].T; if dt > 0 then V = (P - TargetHistory[TPart].P) / dt end else V = Vector3.zero end
    end
    TargetHistory[TPart] = {P = P, T = T}
    for k, v in pairs(TargetHistory) do if tick() - v.T > 1 then TargetHistory[k] = nil end end
    return SafeVector(V)
end

local function GetOmniPrediction(TPart)
    local D = (SafeVector(TPart.Position) - SafeVector(Camera.CFrame.Position)).Magnitude
    local RV = ResolverV6(TPart); local P = 0; pcall(function() P = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000 end)
    local TT = D / Config.BulletSpeed; local TD = (P + TT) * Config.Prediction
    return SafeVector(TPart.Position + (RV * TD) + Vector3.new(0, (Workspace.Gravity * Config.GravityDrop * (TT^2)) / 2, 0))
end

local function BezierInterpolate(t, p0, p1, p2) local u = 1 - t; return (u^2)*p0 + 2*u*t*p1 + (t^2)*p2 end

local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local Method = getnamecallmethod(); local Args = {...}
    if Config.SilentAim and SilentTarget and IsLocalAlive() then
        if (Method == "FindPartOnRayWithIgnoreList" or Method == "FindPartOnRayWithWhitelist" or Method == "FindPartOnRay") and Args[1] then
            Args[1] = Ray.new(SafeVector(Args[1].Origin), SafeVector((GetOmniPrediction(SilentTarget) - SafeVector(Args[1].Origin)).unit * 5000))
            return OldNamecall(self, unpack(Args))
        elseif Method == "Raycast" and Args[1] then
            Args[2] = SafeVector((GetOmniPrediction(SilentTarget) - SafeVector(Args[1])).unit * 5000)
            return OldNamecall(self, unpack(Args))
        elseif Method == "FireServer" and typeof(Args[1]) == "Vector3" then
            Args[1] = GetOmniPrediction(SilentTarget)
            return OldNamecall(self, unpack(Args))
        end
    end
    return OldNamecall(self, ...)
end)

