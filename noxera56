        if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then TextChatService.TextChannels.RBXGeneral:SendAsync(ToxicMessages[math.random(1,#ToxicMessages)])
        else ReplicatedStorage.DefaultChatSystemChatEvents.SayMessageRequest:FireServer(ToxicMessages[math.random(1,#ToxicMessages)], "All") end
    end)
end

local function TriggerHitFeedback()
    if Config.HitSound then task.spawn(function() HitAudio:Play() end) end
