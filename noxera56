local function ExecuteShoot()
    if not IsLocalAlive() or UserInputService:GetFocusedTextBox() then return end
    if tick() - LastShootTick > Config.ShootDelay then
        LastShootTick = tick(); TriggerHitFeedback()
        task.spawn(function()
            if Config.ShootMethod == "Tool" then local T = LocalPlayer.Character:FindFirstChildOfClass("Tool"); if T then T:Activate() end
            elseif Config.ShootMethod == "Mouse API" and HasMouseMoverel then if mouse1click then mouse1click() elseif mouse1press then mouse1press() task.wait(0.01) mouse1release() end
