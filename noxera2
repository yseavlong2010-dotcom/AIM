local function IsValidTarget(Player)
    if Player == LocalPlayer then return false end
    local Char = Player.Character
    if not Char or not Char:IsDescendantOf(Workspace) then return false end 
    local Hum = Char:FindFirstChildOfClass("Humanoid")
    if not Hum or Hum.Health <= 0 then return false end
    if not Char:FindFirstChild("HumanoidRootPart") then return false end

    -- Smart Team Check
    if Config.TeamCheck and LocalPlayer.Team and Player.Team and LocalPlayer.Team == Player.Team then return false end
    
    -- Universal KO Check 
    if Char:FindFirstChild("BodyEffects") then
        local KO = Char.BodyEffects:FindFirstChild("K.O") or Char.BodyEffects:FindFirstChild("KO")
        if KO and KO.Value == true then return false end
    end
    
    return true
end

local function IsVisible(TargetPart)
    local Origin = Camera.CFrame.Position
    local Params = RaycastParams.new()
    Params.FilterType = Enum.RaycastFilterType.Exclude
    Params.FilterDescendantsInstances = {Camera, LocalPlayer.Character, Workspace:FindFirstChild("Ignored"), Workspace:FindFirstChild("Filter")}
    local Result = Workspace:Raycast(Origin, TargetPart.Position - Origin, Params)
    return not Result or Result.Instance:IsDescendantOf(TargetPart.Parent)
end

local function GetAimPart(Char)
    if Config.AimPart == "Torso" then return Char:FindFirstChild("UpperTorso") or Char:FindFirstChild("Torso") or Char:FindFirstChild("HumanoidRootPart") end
    return Char:FindFirstChild(Config.AimPart) or Char:FindFirstChild("HumanoidRootPart")
end

-- [LUỒNG 1]: HEARTBEAT (Xử lý Vật lý & Di chuyển - Chống lag cho Mobile)
local hBeat = RunService.Heartbeat:Connect(function(deltaTime)
    pcall(function()
        local MyChar = LocalPlayer.Character
        local MyHum = MyChar and MyChar:FindFirstChildOfClass("Humanoid")
        local MyHRP = MyChar and MyChar:FindFirstChild("HumanoidRootPart")

        if MyHum and MyHRP then
            if Config.SpeedHack and MyHum.MoveDirection.Magnitude > 0 then
                MyHRP.CFrame = MyHRP.CFrame + (MyHum.MoveDirection * Config.SpeedValue * deltaTime * 10)
            end
            if Config.SpinBot then
                MyHRP.CFrame = MyHRP.CFrame * CFrame.Angles(0, math.rad(Config.SpinSpeed), 0)
            end
            if Config.Fly then
                if not MyHRP:FindFirstChild("NoxFly") then
                    local bv = Instance.new("BodyVelocity"); bv.Name = "NoxFly"; bv.MaxForce = Vector3.new(1e5, 1e5, 1e5); bv.Parent = MyHRP
                end
                MyHRP.NoxFly.Velocity = Camera.CFrame.LookVector * (MyHum.MoveDirection.Z > 0 and -Config.FlySpeed or (MyHum.MoveDirection.Z < 0 and Config.FlySpeed or 0)) + Camera.CFrame.RightVector * (MyHum.MoveDirection.X > 0 and Config.FlySpeed or (MyHum.MoveDirection.X < 0 and -Config.FlySpeed or 0))
            else
                if MyHRP:FindFirstChild("NoxFly") then MyHRP.NoxFly:Destroy() end
            end
        end
        if Config.NoClip and MyChar then for _, v in pairs(MyChar:GetDescendants()) do if v:IsA("BasePart") and v.CanCollide then v.CanCollide = false end end end
    end)
end)
table.insert(Connections, hBeat)

-- [LUỒNG 2]: RENDERSTEPPED (Xử lý Aim, ESP, Camera)
local rStep = RunService.RenderStepped:Connect(function(deltaTime)
    pcall(function()
        Camera = Workspace.CurrentCamera
        local Center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        
        -- UPDATE WATERMARK
        if Config.Watermark and _G.NoxeraWatermark then
            local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
            _G.NoxeraWatermark.Visible = true
            _G.NoxeraWatermark.Text = " NOXERA APEX | FPS: " .. math.floor(1 / deltaTime) .. " | Ping: " .. ping .. "ms "
        elseif _G.NoxeraWatermark then _G.NoxeraWatermark.Visible = false end

        -- FOV RING & CROSSHAIR
        _G.FOVCircle.Position = Center; _G.FOVCircle.Radius = Config.AimFOV; _G.FOVCircle.Visible = Config.AimEnabled
        _G.FOVCircle.Color = LockedTarget and Color3.fromRGB(80, 255, 150) or Color3.fromRGB(255, 255, 255)
        
        if Config.CustomCrosshair then
            _G.CrossX.Visible = true; _G.CrossY.Visible = true
            _G.CrossX.From = Vector2.new(Center.X - 8, Center.Y); _G.CrossX.To = Vector2.new(Center.X + 8, Center.Y)
            _G.CrossY.From = Vector2.new(Center.X, Center.Y - 8); _G.CrossY.To = Vector2.new(Center.X, Center.Y + 8)
        else _G.CrossX.Visible = false; _G.CrossY.Visible = false end

        -- KIỂM TRA MỤC TIÊU ĐANG KHÓA (SMART UN-LOCK & WALL CHECK)
        if LockedTarget then
            local Player = Players:GetPlayerFromCharacter(LockedTarget.Parent)
            if not Player or not IsValidTarget(Player) then 
                LockedTarget = nil 
            else
                if Config.WallCheck and not IsVisible(LockedTarget) then
                    LockedTarget = nil -- Nhả mục tiêu ngay khi khuất tường
                else
                    local Pos, OnScreen = Camera:WorldToViewportPoint(LockedTarget.Position)
                    if not OnScreen or (Vector2.new(Pos.X, Pos.Y) - Center).Magnitude > (Config.AimFOV * 1.5) then LockedTarget = nil end
                end
            end
        end

        local BestDist = Config.AimFOV

        for _, Player in ipairs(Players:GetPlayers()) do
            if not IsValidTarget(Player) then
                if ESP_Library[Player] then for _, v in pairs(ESP_Library[Player]) do v.Visible = false end end
                if Player.Character and Player.Character:FindFirstChild("NoxChams") then Player.Character.NoxChams:Destroy() end
                continue
            end

            local Char = Player.Character
            local HRP = Char:FindFirstChild("HumanoidRootPart")
            local Head = Char:FindFirstChild("Head") or HRP
            local Hum = Char:FindFirstChildOfClass("Humanoid")

            -- Magnetic Hitbox (Silent Aim)
            if Config.SilentAim then
                HRP.Size = Vector3.new(Config.HitboxSize, Config.HitboxSize, Config.HitboxSize)
                HRP.Transparency = 1; HRP.CanCollide = false
            end

            -- Chams
            if Config.ESPChams then
                if not Char:FindFirstChild("NoxChams") then
                    local hl = Instance.new("Highlight", Char); hl.Name = "NoxChams"; hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                end
                Char.NoxChams.FillColor = (LockedTarget and LockedTarget.Parent == Char) and Color3.fromRGB(80, 255, 150) or Color3.fromRGB(255, 50, 50)
            else
                if Char:FindFirstChild("NoxChams") then Char.NoxChams:Destroy() end
            end

            local Pos, OnScreen = Camera:WorldToViewportPoint(HRP.Position)
            local Dist3D = math.floor((Camera.CFrame.Position - HRP.Position).Magnitude)

            -- Drawing ESP
            if OnScreen and Dist3D <= Config.MaxRender and (Config.ESPBox or Config.ESPName or Config.ESPHP or Config.ESPDistance) then
                if not ESP_Library[Player] then
                    ESP_Library[Player] = { Box = Drawing.new("Square"), Name = Drawing.new("Text"), HP = Drawing.new("Square"), Dist = Drawing.new("Text") }
                    local e = ESP_Library[Player]; e.Box.Thickness = 1.5; e.Box.Filled = false
                    e.Name.Size = 14; e.Name.Center = true; e.Name.Outline = true; e.Name.Color = Color3.fromRGB(255, 255, 255)
                    e.HP.Filled = true; e.Dist.Size = 12; e.Dist.Center = true; e.Dist.Outline = true; e.Dist.Color = Color3.fromRGB(200, 200, 200)
                end
                
                local Top, _ = Camera:WorldToViewportPoint(Head.Position + Vector3.new(0, 0.5, 0))
                local Bot, _ = Camera:WorldToViewportPoint(HRP.Position - Vector3.new(0, 3, 0))
                local BoxH = math.abs(Top.Y - Bot.Y); local BoxW = BoxH * 0.55
                local e = ESP_Library[Player]
                
                local espColor = (LockedTarget and LockedTarget.Parent == Char) and Color3.fromRGB(80, 255, 150) or Color3.fromRGB(255, 255, 255)
                
                e.Box.Size = Vector2.new(BoxW, BoxH); e.Box.Position = Vector2.new(Top.X - BoxW/2, Top.Y); e.Box.Color = espColor; e.Box.Visible = Config.ESPBox
                e.Name.Text = Player.Name; e.Name.Position = Vector2.new(Top.X, Top.Y - 15); e.Name.Visible = Config.ESPName
                e.HP.Size = Vector2.new(2, BoxH * (Hum.Health/Hum.MaxHealth)); e.HP.Position = Vector2.new(Top.X - BoxW/2 - 5, Bot.Y - e.HP.Size.Y); e.HP.Color = Color3.fromRGB(0, 255, 0); e.HP.Visible = Config.ESPHP
                e.Dist.Text = "[" .. Dist3D .. "m]"; e.Dist.Position = Vector2.new(Top.X, Bot.Y + 2); e.Dist.Visible = Config.ESPDistance
            else
                if ESP_Library[Player] then for _, v in pairs(ESP_Library[Player]) do v.Visible = false end end
            end

            -- TÌM KIẾM MỤC TIÊU MỚI
            local AimP = GetAimPart(Char)
            if AimP and Config.AimEnabled and not LockedTarget and OnScreen then
                local APos = Camera:WorldToViewportPoint(AimP.Position)
                local Dist2D = (Vector2.new(APos.X, APos.Y) - Center).Magnitude
                if Dist2D < BestDist then
                    if not Config.WallCheck or IsVisible(AimP) then
                        BestDist = Dist2D; LockedTarget = AimP
                    end
                end
            end
        end

        -- 3. EXECUTE AIM & SMART AUTO SHOOT
        if Config.AimEnabled and LockedTarget then
            local PredPos = LockedTarget.Position + (LockedTarget.Velocity * Config.Prediction)
            if Config.AimMode == "Rage" then Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, PredPos)
            else Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position, PredPos), Config.Smoothness) end

            if Config.ShowTargetDot then
                local dp, ds = Camera:WorldToViewportPoint(PredPos)
                if ds then _G.TargetDot.Position = Vector2.new(dp.X, dp.Y); _G.TargetDot.Visible = true else _G.TargetDot.Visible = false end
            else _G.TargetDot.Visible = false end
            
            -- SMART TRIGGERBOT: Chỉ bắn khi mục tiêu không núp tường
            if Config.AutoShoot and tick() - LastShootTick > Config.ShootDelay then
                if not Config.WallCheck or IsVisible(LockedTarget) then
                    local MyChar = LocalPlayer.Character
                    local Tool = MyChar and MyChar:FindFirstChildOfClass("Tool")
                    if Tool then Tool:Activate(); LastShootTick = tick() end
                end
            end
            
            -- AUTO STOMP
            if Config.AutoStomp then
                local EChar = LockedTarget.Parent
                local BE = EChar and EChar:FindFirstChild("BodyEffects")
                local KO = BE and (BE:FindFirstChild("K.O") or BE:FindFirstChild("KO"))
                if KO and KO.Value == true then
                    pcall(function() ReplicatedStorage.MainEvent:FireServer("Stomp") end)
                end
            end

        else 
            _G.TargetDot.Visible = false 
        end
    end)
end)
table.insert(Connections, rStep)

