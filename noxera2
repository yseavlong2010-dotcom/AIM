local leaveCon = Players.PlayerRemoving:Connect(function(P)
    if ESP_Library[P] then for _, v in pairs(ESP_Library[P]) do v:Remove() end; ESP_Library[P] = nil end
end)
table.insert(Connections, leaveCon)
